FLASK_SECRET_KEY=change-me
# Jeśli puste, panel poprosi o ustawienie hasła przy pierwszym wejściu.
APP_PASSWORD=
# Opcjonalny token do zdalnego pierwszego ustawienia hasła.
# Jeśli pusty, pierwsze ustawienie hasła jest dozwolone tylko przez localhost.
APP_SETUP_TOKEN=
APILO_DB_PATH=apilo.sqlite3

# Jeśli konfigurujesz API z poziomu panelu (Ustawienia -> Dane API Apilo),
# zostaw pola APILO_* puste. Wartości z .env mają priorytet nad ustawieniami z panelu.
APILO_BASE_URL=
APILO_CLIENT_ID=
APILO_CLIENT_SECRET=

APILO_GRANT_TYPE=
APILO_AUTH_TOKEN=

# Cache miniaturek (sekundy), 0 = zawsze pobieraj ponownie
THUMB_TTL_SECONDS=86400
THUMB_DOWNLOAD_TIMEOUT_SECONDS=10
THUMB_MAX_DOWNLOAD_BYTES=2000000

# Interwał automatycznej synchronizacji magazynu (sekundy)
REFRESH_INTERVAL_SECONDS=600
SALES_CACHE_REFRESH_INTERVAL_SECONDS=1800
SALES_YEAR_REFRESH_INTERVAL_SECONDS=21600

# Bezpieczenstwo sesji i logowania
SESSION_COOKIE_SECURE=0
SESSION_LIFETIME_MINUTES=480
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
# Ustaw na 1 tylko, jesli aplikacja stoi za zaufanym reverse proxy.
TRUST_X_FORWARDED_FOR=0
