FLASK_SECRET_KEY=change-me
# Jeśli puste, panel poprosi o ustawienie hasła przy pierwszym wejściu.
APP_PASSWORD=
APILO_DB_PATH=apilo.sqlite3

APILO_BASE_URL=https://api.apilo.com
APILO_CLIENT_ID=your_client_id
APILO_CLIENT_SECRET=your_client_secret
APILO_DEVELOPER_ID=

APILO_GRANT_TYPE=authorization_code
APILO_AUTH_TOKEN=your_authorization_code

# Cache miniaturek (sekundy), 0 = zawsze pobieraj ponownie
THUMB_TTL_SECONDS=86400

# Interwał automatycznego odświeżania danych (sekundy)
REFRESH_INTERVAL_SECONDS=600
